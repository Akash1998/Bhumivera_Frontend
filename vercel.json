{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://service.Bhumivera.com/api/$1"
    },
    {
      "src": "/warehouse",
      "dest": "https://service.Bhumivera.com/warehouse"
    },
    {
      "src": "/warehouseadmin",
      "dest": "https://service.Bhumivera.com/warehouseadmin"
    },
    {
      "src": "/assets/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate",
        "pragma": "no-cache",
        "expires": "0"
      },
      "dest": "/index.html"
    }
  ]
}

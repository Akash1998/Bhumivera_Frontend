{
  "version": 2,
  "routes": [
        {
                "src": "/warehouse",
                "dest": "https://service.anritvox.com/warehouse"
              },
        {
                "src": "/warehouse/(.*)",
                "dest": "https://service.anritvox.com/warehouse/$1"
              },
    {
      "src": "/ewarranty",
      "status": 301,
      "headers": {
        "Location": "/warranty"
      }
    },
    {
      "src": "/ewarranty/(.*)",
      "status": 301,
      "headers": {
        "Location": "/warranty/$1"
      }
    },
    {
      "src": "/assets/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "continue": true
    },
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate",
        "pragma": "no-cache",
        "expires": "0"
      },
      "dest": "/index.html"
    }
  ]
}

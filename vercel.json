{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*).(webp|jpg|png|svg|xml|txt|css|js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/api/:path*",
      "destination": "https://service.bhumivera.com/api/:path*"
    },
    {
      "source": "/warehouse",
      "destination": "https://service.bhumivera.com/warehouse"
    },
    {
      "source": "/warehouseadmin",
      "destination": "https://service.bhumivera.com/warehouseadmin"
    },
    {
      "source": "/((?!api/|warehouse|warehouseadmin|sitemap.xml|robots.txt).* )",
      "destination": "/index.html"
    }
  ]
}
